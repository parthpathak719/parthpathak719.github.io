---
import CardProyect from "./CardProyect.astro";
import Section from "../UI/Section.astro";
import { Icon } from "astro-icon/components";
import { FEATURED_PROJECTS } from "../../data/projects";
---

<Section id="projects" title="Projects" titleClassName="mb-24">
    <div class="flex flex-col gap-y-32">
        {FEATURED_PROJECTS.map((project) => <CardProyect {...project} />)}
    </div>

    <a
        href="/projects"
        class="group flex items-center justify-center gap-3 w-full mt-20 py-5 px-6 rounded-2xl border border-white/20 hover:border-primary/60 bg-white/5 hover:bg-white/10 transition-all duration-300 hover:shadow-[0_0_30px_rgba(120,54,207,0.3)] shadow-[0_0_15px_rgba(255,255,255,0.03)]"
        data-aos="fade-up"
    >
        <span class="text-white/70 group-hover:text-white transition-colors duration-300 font-bold tracking-widest text-sm">
            See all projects
        </span>
        <Icon
            name="lucide:arrow-right"
            class="size-4 text-white/50 group-hover:text-primary group-hover:translate-x-1 transition-all duration-300"
        />
    </a>
</Section>
