---
import { BLOGS } from "../../data/blogs";
import Title from "../UI/Title.astro";
---

<section id="blog" class="py-20 px-6">
  <div class="max-w-6xl mx-auto">

    <Title level={2}>
      Blogs
    </Title>

    <div class="grid md:grid-cols-2 gap-8">
      {
        BLOGS.map((blog, index) => (
          <article 
            class="bg-gray-900/50 p-6 rounded-xl border border-white/10 transition duration-300 hover:-translate-y-2 hover:border-primary/50"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <h3 class="text-xl font-semibold text-white mb-2">
              {blog.title}
            </h3>

            <p class="text-sm text-gray-500 mb-3">{blog.date} · {blog.readTime}</p>

            <p class="text-gray-400 mb-4">
              {blog.description}
            </p>

            <a href={blog.link} class="text-primary font-semibold hover:underline transition">
              Read more →
            </a>
          </article>
        ))
      }
    </div>

    <div class="text-center mt-10" data-aos="fade-up">
      <a 
        id="see-all-blogs"
        href="/blog" 
        class="inline-block border border-primary font-semibold px-6 py-3 rounded-xl transition duration-300"
        style="background-color: transparent; color: #7836cf;"
      >
        See All Blogs →
      </a>
    </div>

  </div>
</section>

<script>
  const btn = document.getElementById("see-all-blogs");
  btn?.addEventListener("mouseenter", () => {
    btn.style.backgroundColor = "#512092";
    btn.style.color = "white";
    btn.style.borderColor = "#7836cf";
  });
  btn?.addEventListener("mouseleave", () => {
    btn.style.backgroundColor = "transparent";
    btn.style.color = "#7836cf";
    btn.style.borderColor = "#7836cf";
  });
</script>